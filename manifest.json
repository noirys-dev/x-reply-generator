{
    "manifest_version": 3,
    "name": "aesthetic x reply generator",
    "description": "generate minimal, aesthetic tweet replies with groq ai.",
    "version": "1.0.0",
    "permissions": [
        "storage",
        "activeTab",
        "notifications",
        "clipboardWrite"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.x.com/*",
                "*://*.twitter.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "options_page": "options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}